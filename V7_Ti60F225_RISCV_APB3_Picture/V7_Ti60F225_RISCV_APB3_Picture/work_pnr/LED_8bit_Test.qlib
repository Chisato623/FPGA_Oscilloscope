		timing_arc { type: DELAY from: "I[0]" to: "O" value: 104 }
		timing_arc { type: DELAY from: "I[0]" to: "cout" value: 95 }
		timing_arc { type: DELAY from: "I[1]" to: "O" value: 99 }
		timing_arc { type: DELAY from: "I[1]" to: "cout" value: 95 }
		timing_arc { type: DELAY from: "cin" to: "cout" value: 21 }
		timing_arc { type: SETUP from: "clk" to: "CE" value: 91 active_clock_edge: FALLING }
		timing_arc { type: SETUP from: "clk" to: "I[0]" value: 107 active_clock_edge: FALLING }
		timing_arc { type: SETUP from: "clk" to: "I[1]" value: 102 active_clock_edge: FALLING }
		timing_arc { type: SETUP from: "clk" to: "cin" value: 87 active_clock_edge: FALLING }
