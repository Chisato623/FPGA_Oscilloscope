cell_type {
	name: "io"
	site: io
	port { name: "outpad" dir: IN}
	port { name: "inpad" dir: OUT}
	port { name: "INPAD" dir: IN}
	port { name: "OUTPAD" dir: OUT}
	mode {
		name: "inpad"
		timing_arc { type: DELAY from: "INPAD" to: "inpad" value: 110 }
	}
	mode {
		name: "outpad"
		timing_arc { type: DELAY from: "outpad" to: "OUTPAD" value: 44 }
	}
}
