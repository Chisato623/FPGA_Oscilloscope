	port { name: "fco" dir: OUT}
	port { name: "prop" dir: OUT}
	mode {
		name: "arithmetic"
		site: eft
		timing_arc { type: DELAY from: "I[0]" to: "O" value: 104 }
		timing_arc { type: DELAY from: "I[0]" to: "cout" value: 95 }
		timing_arc { type: DELAY from: "I[1]" to: "O" value: 99 }
		timing_arc { type: DELAY from: "I[1]" to: "cout" value: 95 }
		timing_arc { type: DELAY from: "cin" to: "O" value: 84 }
		timing_arc { type: DELAY from: "cin" to: "cout" value: 21 }
	}
	mode {
		name: "arithmetic_ff_clk_RISING"
		site: eft
		timing_arc { type: DELAY from: "I[0]" to: "O" value: 104 }
		timing_arc { type: DELAY from: "I[0]" to: "cout" value: 95 }
		timing_arc { type: DELAY from: "I[1]" to: "O" value: 99 }
		timing_arc { type: DELAY from: "I[1]" to: "cout" value: 95 }
		timing_arc { type: DELAY from: "cin" to: "cout" value: 21 }
		timing_arc { type: SETUP from: "clk" to: "CE" value: 91 active_clock_edge: RISING }
		timing_arc { type: SETUP from: "clk" to: "I[0]" value: 107 active_clock_edge: RISING }
		timing_arc { type: SETUP from: "clk" to: "I[1]" value: 102 active_clock_edge: RISING }
		timing_arc { type: SETUP from: "clk" to: "cin" value: 87 active_clock_edge: RISING }
		timing_arc { type: SETUP from: "clk" to: "RE" value: 91 active_clock_edge: RISING }
		timing_arc { type: CLK_TO_Q from: "clk" to: "O_seq" value: 113 active_clock_edge: RISING }
	}
	mode {
		name: "arithmetic_ff_clk_FALLING"
