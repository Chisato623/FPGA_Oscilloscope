eclipse.preferences.version=1
gdb.client.commands=set mem inaccessible-by-default off\r\nset arch riscv\:rv32\r\nset remotetimeout 250
gdb.client.doStart=true
gdb.client.executable=${eclipse_home}/../toolchain/bin/riscv-none-embed-gdb.exe
gdb.client.other=
gdb.openocd.doDebugInRam=true
gdb.openocd.doInitialReset=true
gdb.openocd.doPreRunReset=true
gdb.openocd.enableSemihosting=true
gdb.openocd.init.other=
gdb.openocd.initialReset.type=init
gdb.openocd.preRun.other=
gdb.openocd.preRunReset.type=halt
gdb.server.doStart=true
gdb.server.executable=${eclipse_home}/../openocd/bin/openocd.exe
gdb.server.other=-c 'set bsp_loc {F\:\\usefullMaterial\\new\\Ti60\\V7_Ti60F225_RISCV_APB3_Picture\\embedded_sw\\soc_test}'\r\n-f 'F\:\\usefullMaterial\\new\\Ti60\\V7_Ti60F225_RISCV_APB3_Picture\\embedded_sw\\soc_test/bsp/efinix/EfxSapphireSoc/openocd/ftdi_ti.cfg'\r\n-f 'F\:\\usefullMaterial\\new\\Ti60\\V7_Ti60F225_RISCV_APB3_Picture\\embedded_sw\\soc_test/bsp/efinix/EfxSapphireSoc/openocd/debug_ti.cfg'
