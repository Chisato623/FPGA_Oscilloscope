Instance Name                 : pll_inst1
Resource                      : PLL_TL0
Locked Pin Name               : pll_inst1_LOCKED
Clock Source                  : external
Reference Clock Resource      : GPIOL_11
Reference Clock               : clk
Feedback Mode                 : local
Feedback Clock                : pll_inst1_CLKOUT0

Reference Clock Frequency     : 24.0000 MHz
Reference Clock Period        : 41.6667 ns
Multiplier (M)                : 4
Pre-Divider (N)               : 1
VCO Frequency                 : 4992.0000 MHz
Post-Divider (O)              : 2
PLL Frequency                 : 2496.0000 MHz

Output Clock 0
Clock Pin Name                : pll_inst1_CLKOUT0
Output Divider                : 26
Dynamic Phase Shift           : Disable
Phase Setting                 : 0
Phase Degree                  : 0.0000
Invert Output                 : false
Output Frequency              : 96.0000 MHz
Output Period                 : 10.417 ns

Output Clock 1
Clock Pin Name                : clk_pixel_parallel
Output Divider                : 100
Dynamic Phase Shift           : Disable
Phase Setting                 : 0
Phase Degree                  : 0.0000
Invert Output                 : false
Output Frequency              : 24.9600 MHz
Output Period                 : 40.064 ns

Output Clock 2
Clock Pin Name                : clk_pixel_serial
Output Divider                : 10
Dynamic Phase Shift           : Disable
Phase Setting                 : 5
Phase Degree                  : 90.0000
Invert Output                 : false
Output Frequency              : 249.6000 MHz
Output Period                 : 4.006 ns

Frequency calculations:
	VCO = REFCLK * ((M * FBK) /N)
	    = 24.0000 MHz * ((4*52) /1)
	    = 4992.0000 MHz
	PLL = VCO / O
	    = 4992.0000 MHz / 2
	    = 2496.0000 MHz

	CLKOUT0 = PLL / CLKOUT0_DIV
	        = 2496.0000 MHz / 26
	        = 96.0000 MHz
	CLKOUT1 = PLL / CLKOUT1_DIV
	        = 2496.0000 MHz / 100
	        = 24.9600 MHz
	CLKOUT2 = PLL / CLKOUT2_DIV
	        = 2496.0000 MHz / 10
	        = 249.6000 MHz

SDC Constraints:
	create_clock -period 10.417 -name pll_inst1_CLKOUT0 [get_ports {pll_inst1_CLKOUT0}]
	create_clock -period 40.064 -name clk_pixel_parallel [get_ports {clk_pixel_parallel}]
	create_clock -waveform {1.002 3.005} -period 4.006 -name clk_pixel_serial [get_ports {clk_pixel_serial}]

