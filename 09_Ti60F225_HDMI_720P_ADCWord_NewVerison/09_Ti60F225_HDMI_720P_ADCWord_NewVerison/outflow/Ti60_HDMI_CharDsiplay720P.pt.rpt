Frequency calculations:
	VCO = REFCLK * ((M * FBK) /N)
	    = 24.0000 MHz * ((1*180) /1)
	    = 4320.0000 MHz
	PLL = VCO / O
	    = 4320.0000 MHz / 2
	    = 2160.0000 MHz

	CLKOUT0 = PLL / CLKOUT0_DIV
	        = 2160.0000 MHz / 90
	        = 24.0000 MHz
	CLKOUT1 = PLL / CLKOUT1_DIV
	        = 2160.0000 MHz / 80
	        = 27.0000 MHz
	CLKOUT2 = PLL / CLKOUT2_DIV
	        = 2160.0000 MHz / 54
	        = 40.0000 MHz

